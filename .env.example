# Telegram Bot Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# Required: Get this from @BotFather on Telegram
TELEGRAM_TOKEN=your_bot_token_here

# Required: Get this from Overseerr settings > API
OVERSEERR_API_KEY=your_overseerr_api_key_here

# Required: Your Telegram chat ID (can get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Seerr base URL (same pattern as Radarr below).
# Omit on same Compose/K8s network as Seerr (defaults to http://seerr:5055).
# Local / remote examples:
# OVERSEERR_URL=http://localhost:5055
# OVERSEERR_URL=http://host.docker.internal:5055
# Or: OVERSEERR_HOST=overseerr OVERSEERR_PORT=5055
OVERSEERR_URL=http://localhost:5055

# Optional: Radarr (MEDIA_AVAILABLE — downloaded quality + movie folder for movies).
# Same pattern as OVERSEERR_URL: full URL, or RADARR_HOST + RADARR_PORT.
# Omit on same Compose/K8s network as Radarr (defaults to http://radarr:7878).
# RADARR_URL=http://localhost:7878
RADARR_API_KEY=

# Optional: Webhook server configuration
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=7777
WEBHOOK_PATH=/overseerr/requests

# Optional: Webhook authentication token
# Set this in both bot and Overseerr webhook configuration for security
WEBHOOK_TOKEN=
